# LiveRead local development environment (host-run API/web; infra in Docker)
# Copy to .env — never commit real secrets.

NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://liveread:liveread@localhost:5433/liveread
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=liveread-recordings
S3_ACCESS_KEY=liveread
S3_SECRET_KEY=liveread-secret
SMTP_URL=smtp://localhost:1025
WEB_ORIGINS=http://localhost:3000
APP_BASE_URL=http://localhost:3000
COOKIE_SECRET=local-dev-cookie-secret-change-in-production

# Speech-to-text: "fake" needs no credentials and powers the full demo.
STT_PROVIDER=fake
STT_FALLBACK_PROVIDER=fake
# DEEPGRAM_API_KEY=            # set to enable the real streaming provider

# Dev conveniences
EMAIL_AUTOVERIFY=true
# FAKE_STT_MS_PER_WORD=280     # lower to speed up the fake provider in tests

# LiveKit (optional live creator audio; compose profile "media")
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret-local-only-0000000000000000

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000
